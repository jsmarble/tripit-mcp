{
  "name": "tripit-mcp",
  "version": "2.0.0",
  "description": "Public remote MCP server for the TripIt travel management API on Cloudflare Workers — bring your own OAuth credentials",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "check": "tsc --noEmit && tsc -p test --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "authorize": "node scripts/authorize.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.17.3",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@types/node": "^26.1.1",
    "msw": "^2.15.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  },
  "allowScripts": {
    "workerd@1.20260708.1": true,
    "sharp@0.34.5": true,
    "core-js-pure@3.49.0": true,
    "esbuild@0.28.1": true,
    "msw@2.15.0": true
  }
}
