# Copy to .dev.vars for local development with `wrangler dev`.
#
# All values are OPTIONAL. Callers normally supply their own TripIt
# credentials per-request via the X-TripIt-* headers.

# This deployment's registered TripIt API application (register one at
# https://www.tripit.com/developer). Enables the hosted /connect browser flow
# and access-token-pair-only authentication.
# TRIPIT_CONSUMER_KEY=your_app_consumer_key
# TRIPIT_CONSUMER_SECRET=your_app_consumer_secret

# Optional fallback access-token pair for a private single-user deployment
# (requires the consumer values above too): keyless requests then act on this
# TripIt account. Leave unset for a shared server. Mint a pair via the
# /connect flow or `npm run authorize -- <consumer_key> <consumer_secret>`.
# TRIPIT_ACCESS_TOKEN=your_access_token
# TRIPIT_ACCESS_TOKEN_SECRET=your_access_token_secret

# Optional: enforce Cloudflare Access JWT validation in the Worker.
# Leave unset for local development.
# ACCESS_TEAM_DOMAIN=myteam
# ACCESS_APP_AUD=your_access_application_aud_tag
